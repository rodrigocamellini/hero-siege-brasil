rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar se é o administrador
    function isAdmin() {
      return request.auth != null && request.auth.uid == "hfsHCehqYgen7OAfXUYl58fEPo02";
    }

    // Posts e comentários
    match /posts/{postId} {
      // Público vê apenas publicados, Admin vê tudo (rascunhos, etc)
      allow read: if resource.data.status == "published" || isAdmin();
      allow write: if isAdmin();

      match /comments/{commentId} {
        allow create: if true;
        allow read: if resource.data.approved == true || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // Config da Homepage (imagem destacada/aleatória)
    match /config/homepage {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tierlist (S/A/B/C/D/E)
    match /config/tierlist {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // NOVA REGRA: Equipe / Colaboradores
    // Necessário para a aba "Configurações" do painel e a página "Equipe"
    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações da Árvore Ether (Nodes e Detalhes)
    // Permite que qualquer um leia os detalhes dos nós (nome, status, etc)
    // Apenas admin pode editar via Painel
    match /ether_tree_nodes/{nodeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Builds do Forum (O site usa a rota /forum, mas o banco usa a coleção 'builds')
    match /builds/{buildId} {
      // Público só enxerga builds já publicadas, Admin vê tudo
      allow read: if resource.data.status == "published" || isAdmin();

      // Qualquer um pode ENVIAR uma nova build (Nova Build no site)
      allow create: if true;

      // Só o admin pode editar/aprovar/deletar (via Painel)
      allow update, delete: if isAdmin();
    }

    // Mensagens do formulário de contato
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // 1. Regra específica para a coleção de Backups
    match /backups/{backup} {
      allow read, write: if isAdmin();
    }

    // 2. Regra GLOBAL para o Admin (Essencial para o Backup/Restore funcionar)
    // O Admin precisa poder ler/escrever em posts, builds, team, config, etc.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Regra Padrão (Fallback)
    // Mantém compatibilidade com outras coleções (classes, items, etc)
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
